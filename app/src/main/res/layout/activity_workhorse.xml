<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- TOP BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="32dp"
            app:srcCompat="@drawable/os5_logoicon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:id="@+id/introtext"
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:srcCompat="@drawable/os_introtext"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- MIDDLE CONTAINER - Contains background and response display -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/middle_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/top_container"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Background image -->
        <ImageView
            android:id="@+id/background"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/workhorse_background"
            android:scaleType="centerCrop"
            android:scaleX="1.25"
            android:scaleY="1.0"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- QUESTION 1: Time Investment Question -->
        <LinearLayout
            android:id="@+id/question_time_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:visibility="visible"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/question_time_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How many minutes do you want to invest in this project everyday?"
                android:textSize="22sp"
                android:textColor="#333333"
                android:fontFamily="@font/neuehaas45"
                android:textAlignment="center"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="40dp" />

            <NumberPicker
                android:id="@+id/minutes_picker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:theme="@style/Theme.AppCompat.Light" />

            <TextView
                android:id="@+id/continue_time_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/input_outline"
                android:backgroundTint="#333333"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/neuehaas45"
                android:paddingHorizontal="48dp"
                android:paddingVertical="16dp"
                android:text="Continue"
                android:textColor="#000000"
                android:textSize="18sp" />

        </LinearLayout>

        <!-- QUESTION 2: Completion Date Question -->
        <LinearLayout
            android:id="@+id/question_date_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/question_date_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="When do you want to complete this project by?"
                android:textSize="22sp"
                android:textColor="#333333"
                android:fontFamily="@font/neuehaas45"
                android:textAlignment="center"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="40dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="40dp">

                <NumberPicker
                    android:id="@+id/day_picker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:theme="@style/Theme.AppCompat.Light" />

                <NumberPicker
                    android:id="@+id/month_picker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:theme="@style/Theme.AppCompat.Light" />

                <NumberPicker
                    android:id="@+id/year_picker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:theme="@style/Theme.AppCompat.Light" />

            </LinearLayout>

            <TextView
                android:id="@+id/continue_date_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/input_outline"
                android:backgroundTint="#333333"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/neuehaas45"
                android:paddingHorizontal="48dp"
                android:paddingVertical="16dp"
                android:text="Continue"
                android:textColor="#000000"
                android:textSize="18sp" />

        </LinearLayout>

        <!-- Timeline exceeded warning message -->
        <LinearLayout
            android:id="@+id/timeline_warning_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/warning_ion_logo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                app:srcCompat="@drawable/ionlogo" />

            <TextView
                android:id="@+id/timeline_warning_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Your project is ambitious and exceeded the timeline you entered, I've created a more appropriate schedule for you to follow."
                android:textSize="14sp"
                android:textColor="#666666"
                android:fontFamily="@font/neuehaas45"
                android:lineSpacingMultiplier="1.2" />

        </LinearLayout>

        <!--
            MILESTONE LIST DISPLAY AREA
            RecyclerView to show milestone cards with timeline
            Extends to bottom of screen with padding to account for bottom nav
        -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/milestone_list"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginVertical="16dp"
            android:background="@null"
            android:clipToPadding="false"
            android:paddingBottom="120dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/timeline_warning_container"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BOTTOM NAVIGATION BAR -->
    <include
        android:id="@+id/bottom_nav_include"
        layout="@layout/bottom_navigation_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- BOTTOM CONTAINER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:animateLayoutChanges="true"
        android:background="@android:color/transparent"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav_include"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- LOADING STATUS - Ion logo + cycling status text (above input box) -->
        <LinearLayout
            android:id="@+id/loading_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@id/input_box"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Ion logo displayed during loading -->
            <ImageView
                android:id="@+id/ion_logo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:srcCompat="@drawable/ionlogo" />

            <!-- Cycling status text displayed during loading -->
            <TextView
                android:id="@+id/loading_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/neuehaas25"
                android:text="waiting..."
                android:textColor="#666666"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- INPUT BOX (at bottom) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/input_box"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/input_outline"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp"
            android:animateLayoutChanges="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/user_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@null"
                android:fontFamily="@font/neuehaas45"
                android:hint="Type here..."
                android:textSize="16sp"
                android:inputType="textMultiLine"
                android:minLines="1"
                android:maxLines="6"
                android:gravity="top|start"
                android:imeOptions="actionSend"
                android:maxLength="2000"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/enter_arrow"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageView
                android:id="@+id/enter_arrow"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:clickable="true"
                android:focusable="true"
                app:srcCompat="@drawable/os_enterarrow"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>