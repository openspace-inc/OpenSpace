<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- TOP BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="32dp"
            app:srcCompat="@drawable/os5_logoicon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:id="@+id/introtext"
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:srcCompat="@drawable/os_introtext"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- MIDDLE CONTAINER - Contains background and response display -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/middle_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/top_container"
        app:layout_constraintBottom_toTopOf="@id/bottom_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Background image -->
        <ImageView
            android:id="@+id/background"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/workhorse_background"
            android:scaleType="centerCrop"
            android:scaleX="1.25"
            android:scaleY="1.0"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!--
            RESPONSE DISPLAY AREA
            ScrollView with fully transparent background
        -->
        <ScrollView
            android:id="@+id/response_scroll"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:overScrollMode="never"
            android:requiresFadingEdge="none"
            android:fadingEdgeLength="0dp"
            android:layout_margin="16dp"
            android:fillViewport="true"
            android:background="@null"
            android:scrollbars="none"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!--
                TextView to display Claude's response
                Fully transparent background - no grey box
            -->
            <TextView
                android:id="@+id/response_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/neuehaas45"
                android:textSize="16sp"
                android:textColor="#333333"
                android:lineSpacingMultiplier="1.3"
                android:padding="8dp"
                android:background="@null" />

        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BOTTOM CONTAINER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:animateLayoutChanges="true"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- LOADING STATUS - Ion logo + cycling status text (above input box) -->
        <LinearLayout
            android:id="@+id/loading_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@id/input_box"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Ion logo displayed during loading -->
            <ImageView
                android:id="@+id/ion_logo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:srcCompat="@drawable/ionlogo" />

            <!-- Cycling status text displayed during loading -->
            <TextView
                android:id="@+id/loading_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/neuehaas25"
                android:text="waiting..."
                android:textColor="#666666"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- INPUT BOX (at bottom) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/input_box"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/input_outline"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp"
            android:animateLayoutChanges="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/user_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@null"
                android:fontFamily="@font/neuehaas45"
                android:hint="Type here..."
                android:textSize="16sp"
                android:inputType="textMultiLine"
                android:minLines="1"
                android:maxLines="6"
                android:gravity="top|start"
                android:imeOptions="actionSend"
                android:maxLength="2000"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/enter_arrow"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageView
                android:id="@+id/enter_arrow"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:clickable="true"
                android:focusable="true"
                app:srcCompat="@drawable/os_enterarrow"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>