<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- TOP BAR -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/logo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="32dp"
            app:srcCompat="@drawable/os5_logoicon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageView
            android:id="@+id/introtext"
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:srcCompat="@drawable/os_introtext"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageButton
            android:id="@+id/back_button"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_marginEnd="32dp"
            android:background="@null"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/back"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- MIDDLE CONTAINER - Contains background and response display -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/middle_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/top_container"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Background image -->
        <ImageView
            android:id="@+id/background"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:src="@drawable/workhorse_background"
            android:scaleType="centerCrop"
            android:scaleX="1.25"
            android:scaleY="1.0"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- QUESTION 1: Time Investment Question -->
        <LinearLayout
            android:id="@+id/question_time_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/question_time_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:fontFamily="@font/neuehaas45"
                android:lineSpacingMultiplier="1.3"
                android:text="How many minutes do you want to invest in this project everyday?"
                android:textAlignment="center"
                android:textColor="#333333"
                android:textSize="22sp" />

            <NumberPicker
                android:id="@+id/minutes_picker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:theme="@style/Theme.AppCompat.Light" />

            <TextView
                android:id="@+id/continue_time_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/input_outline"
                android:backgroundTint="#333333"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/neuehaas45"
                android:paddingHorizontal="48dp"
                android:paddingVertical="16dp"
                android:text="Continue"
                android:textColor="#000000"
                android:textSize="18sp" />

        </LinearLayout>

        <!-- QUESTION 2: Completion Date Question -->
        <LinearLayout
            android:id="@+id/question_date_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/question_date_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="When do you want to complete this project by?"
                android:textSize="22sp"
                android:textColor="#333333"
                android:fontFamily="@font/neuehaas45"
                android:textAlignment="center"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="40dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="40dp">

                <NumberPicker
                    android:id="@+id/day_picker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:theme="@style/Theme.AppCompat.Light" />

                <NumberPicker
                    android:id="@+id/month_picker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:theme="@style/Theme.AppCompat.Light" />

                <NumberPicker
                    android:id="@+id/year_picker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:theme="@style/Theme.AppCompat.Light" />

            </LinearLayout>

            <TextView
                android:id="@+id/continue_date_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/input_outline"
                android:backgroundTint="#333333"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/neuehaas45"
                android:paddingHorizontal="48dp"
                android:paddingVertical="16dp"
                android:text="Continue"
                android:textColor="#000000"
                android:textSize="18sp" />

        </LinearLayout>

        <!-- Timeline exceeded warning message -->
        <LinearLayout
            android:id="@+id/timeline_warning_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            android:paddingVertical="16dp"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/warning_ion_logo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="12dp"
                app:srcCompat="@drawable/ionlogo" />

            <TextView
                android:id="@+id/timeline_warning_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Your project is ambitious and exceeded the timeline you entered, I've created a more appropriate schedule for you to follow."
                android:textSize="14sp"
                android:textColor="#666666"
                android:fontFamily="@font/neuehaas45"
                android:lineSpacingMultiplier="1.2" />

        </LinearLayout>

        <!--
            MILESTONE LIST DISPLAY AREA
            RecyclerView to show milestone cards with timeline
            Extends to bottom of screen with padding for bottom container
        -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/milestone_list"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginVertical="16dp"
            android:background="@null"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/timeline_warning_container"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Continue button after milestones are displayed -->
        <TextView
            android:id="@+id/continue_milestone_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/input_outline"
            android:backgroundTint="#333333"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/neuehaas45"
            android:paddingHorizontal="48dp"
            android:paddingVertical="16dp"
            android:text="Continue"
            android:textColor="#000000"
            android:textSize="18sp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- INVESTMENT VIEW - Shown after user presses continue on milestones -->
        <LinearLayout
            android:id="@+id/investment_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingTop="32dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Header with ion logo and description text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/investment_ion_logo"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="16dp"
                    app:srcCompat="@drawable/ionlogo" />

                <TextView
                    android:id="@+id/investment_description"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/neuehaas45"
                    android:lineSpacingMultiplier="1.3"
                    android:text="Your project has been created, now choose an investment amount for your first stock in the project."
                    android:textColor="#333333"
                    android:textSize="16sp" />

            </LinearLayout>

            <!-- Investment amount display with block image -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Container for animated number -->
                <FrameLayout
                    android:id="@+id/investment_number_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clipChildren="true"
                    android:clipToPadding="true">

                    <EditText
                        android:id="@+id/investment_amount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:cursorVisible="false"
                        android:fontFamily="@font/neuehaas65"
                        android:gravity="center"
                        android:inputType="number"
                        android:minWidth="60dp"
                        android:text="0"
                        android:textColor="#000000"
                        android:textSize="128sp" />

                </FrameLayout>

                <ImageView
                    android:id="@+id/investment_block_icon"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="8dp"
                    app:srcCompat="@drawable/os5_blockv2" />

            </LinearLayout>

            <!-- Current worth display -->
            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FAF9F6"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp">

                    <TextView
                        android:id="@+id/current_worth_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/neuehaas45"
                        android:text="Currently: "
                        android:textColor="#666666"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/current_worth_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/neuehaas45"
                        android:text="0"
                        android:textColor="#666666"
                        android:textSize="16sp" />

                    <ImageView
                        android:id="@+id/current_worth_block_icon"
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_marginStart="4dp"
                        app:srcCompat="@drawable/os5_blockv2" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/current_worth_note"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/neuehaas25"
                android:text="The higher the investment, the faster the rise of the stock, but it also means a more risky project to ignore."
                android:textAlignment="center"
                android:textColor="#666666"
                android:textSize="16sp" />

            <!-- Spacer to push finalize button to bottom -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Finalize button -->
            <TextView
                android:id="@+id/finalize_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/input_outline"
                android:backgroundTint="#333333"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/neuehaas45"
                android:paddingHorizontal="48dp"
                android:paddingVertical="16dp"
                android:text="Finalize Investment"
                android:textColor="#000000"
                android:textSize="18sp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- BOTTOM CONTAINER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:animateLayoutChanges="true"
        android:background="@android:color/transparent"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- LOADING STATUS - Ion logo + cycling status text (above input box) -->
        <LinearLayout
            android:id="@+id/loading_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@id/input_box"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Ion logo displayed during loading -->
            <ImageView
                android:id="@+id/ion_logo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                app:srcCompat="@drawable/ionlogo" />

            <!-- Cycling status text displayed during loading -->
            <TextView
                android:id="@+id/loading_status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/neuehaas25"
                android:text="waiting..."
                android:textColor="#666666"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- INPUT BOX (at bottom) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/input_box"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/input_outline"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp"
            android:animateLayoutChanges="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/user_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@null"
                android:fontFamily="@font/neuehaas45"
                android:hint="Type here..."
                android:textSize="16sp"
                android:inputType="textMultiLine"
                android:minLines="1"
                android:maxLines="6"
                android:gravity="top|start"
                android:imeOptions="actionSend"
                android:maxLength="2000"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/enter_arrow"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <ImageView
                android:id="@+id/enter_arrow"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:clickable="true"
                android:focusable="true"
                app:srcCompat="@drawable/os_enterarrow"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>