<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer gradient ring -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="sweep"
                android:startColor="#feda75"
                android:centerColor="#d62976"
                android:endColor="#962fbf" />
        </shape>
    </item>

    <!-- Inner white circle to create a gap between the ring and image -->
    <item
        android:top="4dp"
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/white" />
        </shape>
    </item>
</layer-list>
