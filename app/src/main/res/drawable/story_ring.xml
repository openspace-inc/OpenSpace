<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer gradient ring -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:startColor="@color/red"
                android:centerColor="#FFB886"
                android:endColor="@color/tan"
                android:angle="45"/>
        </shape>
    </item>

    <!-- Inner white circle to create a gap between the ring and image -->
    <item
        android:top="4dp"
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/white" />
        </shape>
    </item>
</layer-list>
